# ──────────────────────────────────────────────
# AutoReel Lite — Environment Variables
# ──────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://autoreel:autoreel@localhost:5432/autoreel"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# NextAuth
AUTH_SECRET="generate-a-strong-random-secret-here"
AUTH_URL="http://localhost:3000"
# Trust host in dev (set to true)
AUTH_TRUST_HOST=true

# Admin email — first user seeded as ADMIN
ADMIN_EMAIL="admin@example.com"

# ──────────────────────────────────────────────
# Mock Mode (set to "true" for dev without real API keys)
# ──────────────────────────────────────────────
USE_MOCK_PUBLISHERS="false"

# ──────────────────────────────────────────────
# Meta OAuth (Facebook + Instagram)
# ──────────────────────────────────────────────
META_APP_ID=""
META_APP_SECRET=""
META_REDIRECT_URI="http://localhost:3000/api/social/meta/callback"

# ──────────────────────────────────────────────
# Google OAuth (YouTube + Google Drive)
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/social/google/callback"

# ──────────────────────────────────────────────
# Upload Settings
# ──────────────────────────────────────────────
MAX_FILE_SIZE_MB="500"
UPLOAD_DIR="./uploads"

# ──────────────────────────────────────────────
# Token Encryption Key (32 hex chars)
# ──────────────────────────────────────────────
TOKEN_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"
